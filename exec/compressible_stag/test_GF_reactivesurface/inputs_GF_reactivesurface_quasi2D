# random number seed
# 0 = unpredictable seed based on clock
# positive = fixed seed
seed = 0

# Problem specification
prob_lo = 0.0 0.0 0.0 # physical lo coordinate
prob_hi = 2.875392e-02 3.594240e-03 2.808000e-05 # physical hi coordinate

# Number of ghost cells, conserved, and primitive variables
# ---------------------
ngc = 2 2 2
nvars = 7
nprimvars = 10

# number of cells in domain
n_cells = 1024 128 1
# max number of cells in a box
max_grid_size = 32 16 1
max_grid_projection = 32 16 1

# Time-step control
fixed_dt = 1.0e-10

# Controls for number of steps between actions

max_step = 12000000
plot_int = 2000000
chk_int  = 2000000
n_steps_skip = 2000000

do_2D = 1
project_dir = 2
slicepoint = 0

ads_wall_dir = 1

struct_fact_int = 10

# Multispecies toggle
# if algorithm_type = 1, single component
# if algorithm_type = 2, multispecies
algorithm_type = 2

# Viscous tensor form
# if visc_type = 1, L = not-symmetric (bulk viscosity = 0)
# if visc_type = 2, L = symmetric (bulk viscosity = 0)
# if visc_type = 3, L = symmetric + bulk viscosity
visc_type = 2

# Advection method
# if advection_type = 1, interpolate primitive quantities
# if advection_type = 2, interpolate conserved quantities
advection_type = 2

transport_type = 1

# Problem specification
# if prob_type = 1, constant species concentration
# if prob_type = 2, Rayleigh-Taylor instability
# if prob_type = 3, diffusion barrier
prob_type = 1

# Initial parameters
k_B = 1.38064852e-16	# [units: cm2*g*s-2*K-1]
T_init = 273
rho0 = 2.500707e-03

# Boundary conditions:
# NOTE: setting bc_vel to periodic sets all the other bc's to periodic)
# bc_vel:   -1 = periodic
#            1 = slip
#            2 = no-slip
# bc_mass:  -1 = periodic
#            1 = wall
#            2 = reservoir (set bc_Yk or bc_Xk in compressible namelist)
# bc_therm: -1 = periodic
#            1 = adiabatic
#            2 = isothermal (set with t_lo/hi in common namelist)
bc_vel_lo   = -1 2 -1
bc_vel_hi   = -1 2 -1
bc_mass_lo  = -1 1 -1
bc_mass_hi  = -1 2 -1
bc_therm_lo = -1 2 -1
bc_therm_hi = -1 2 -1

# Temperature if thermal BC specified
t_hi = 273 273 273
t_lo = 273 273 273

bc_Yk_y_hi = 0.90 0.10

#Kinetic species info
#--------------
nspecies = 2

molmass = 28.01 28.01
diameter = 3.76e-8 3.76e-8
rhobar = 0.40 0.60

# Enter negative dof to use hcv & hcp values
dof = 5 5
hcv = -1 -1
hcp = -1 -1

plot_means = 1

# MFsurfchem

# number of adsorption species
# n_ads_spec = 0 (if no adsorption species)
n_ads_spec = 1

# stoch_surfcov0 = 0 (Initially uniform)
stoch_surfcov0 = 0

# initial surface coverage
surfcov0 = 0.626
# number density of adsorption sites on the lattice
surf_site_num_dens = 1.027285e+15

# adsorption rate = ads_rate_const * num_dens
# desoprtion rate = des_rate
ads_rate_const = 2.933022e+01
des_rate = 1.582823e+06

conversion_MFsurfchem = 1

splitting_MFsurfchem = 1
